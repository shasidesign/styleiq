# FitAI Environment Variables
# Copy this file to .env and fill in your values

# Flask
SECRET_KEY=your-super-secret-key-change-this-in-production-use-long-random-string

# MongoDB Atlas Connection String
# Get this from https://cloud.mongodb.com → Connect → Drivers
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/fitai?retryWrites=true&w=majority

# OpenAI API Key (optional — app works without it using rule-based fallback)
# Get this from https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-key-here

# Flask Environment
FLASK_ENV=development
FLASK_DEBUG=1
